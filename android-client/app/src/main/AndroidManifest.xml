<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.displaybridge.probe">

    <!-- M1.2: video pipeline needs local TCP loopback (adb forward) access.
         INTERNET is required even for 127.0.0.1 sockets on API 26+. No
         other M0.3/M0.4 code needed this permission before. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- M1.2 foreground service (VideoStreamService) keeps decode alive
         when the tablet screen is off/locked (see CONTEXT-BRIEF §5 HONOR
         MagicOS background-kill note). Uses mediaPlayback type, see below. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- mediaPlayback, not connectedDevice and not dataSync.
         connectedDevice threw SecurityException on-device without a
         USB/BT/CompanionDeviceManager permission we don't hold.
         dataSync was tried next and works, but on targetSdk 36 (Android
         15+/16 restrictions active on this device) dataSync is deprecated
         and subject to a ~6h rolling runtime cap; the OS force-stops the
         FGS after the budget, which would break an indefinite display
         mirror (and the M4.5 "2h screen-off, service alive" soak DoD as
         sessions lengthen).
         mediaPlayback is the semantically-correct type for continuous
         video playback in the background, has no time cap, and needs no
         extra runtime permission. A display mirror IS continuous video
         playback. See VideoStreamService.onCreate() comment. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Session 19: PcPresenceWatcherService (background PC detector).
         specialUse because no typed FGS category covers "poll a loopback
         socket through adb reverse"; the subtype property on the service
         declares intent for review tooling. POST_NOTIFICATIONS is needed
         on API 33+ for both the ongoing watcher notification and the
         high-priority "PC san sang, ket noi?" prompt. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:label="DisplayBridge Codec Probe"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:debuggable="true">

        <!--
            M0.3 codec-probe activity. Diagnostic-only tool (dumps
            MediaCodec PerformancePoints to Logcat), NOT a user-facing app.
            Deliberately has NO LAUNCHER intent-filter so it doesn't show a
            second confusing "DisplayBridge Codec Probe" icon on the tablet's
            home screen alongside the real app (user-reported 2026-07-04:
            "build ra 2 cai, 1 cai chi la du lieu test"). Still reachable for
            manual diagnostics via:
              adb shell am start -n com.displaybridge.probe/.CodecProbeActivity
        -->
        <activity
            android:name="com.displaybridge.probe.CodecProbeActivity"
            android:exported="true" />

        <!--
            M1.2 video decoder Activity (com.displaybridge.video package).
            Exported+launchable independently so it can be started directly
            via `adb shell am start` for manual testing without a full
            handshake/launcher flow (M1.3 will wire this into the real
            CAPS/CONFIG handshake entry point).
        -->
        <activity
            android:name="com.displaybridge.video.VideoDecoderActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="landscape">
            <!--
                Session 17 originally pinned this Activity fullscreen-only
                (resizeableActivity=false, supportsPictureInPicture=false)
                because Honor "App Multiplier" freeform windows made
                sendCaps() report the WINDOW size (~1519x1517) instead of
                the physical 3000x1920 panel, and the PC resized the
                virtual display to match. Session 18 (user request: "khong
                bat buoc full man hinh") removed that restriction; the
                real fix moved into ControlSocketClient.sendCaps(), which
                now reads Display.getRealMetrics() (physical panel size,
                window-mode independent), so CAPS stays 3000x1920 whether
                the app runs fullscreen, split-screen, or in a freeform
                floating window.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.displaybridge.video.VideoStreamService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Session 19: background PC-presence watcher (see the permission
             block comment above for the specialUse rationale). -->
        <service
            android:name="com.displaybridge.presence.PcPresenceWatcherService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="pc-presence-watch" />
        </service>
    </application>
</manifest>
