<Window x:Class="DisplayBridge.Host.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayBridge Settings" Height="520" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Display" FontWeight="Bold" Margin="0,0,0,6" />

        <!-- 2026-07-03 decision (session 7): resolution is no longer a user
             choice — always 100% native, derived live from DeviceCaps (CAPS
             handshake). Read-only display only, no ComboBox/TextBox. -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolution" VerticalAlignment="Center" />
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ResolutionValueText" Margin="0,4" VerticalAlignment="Center" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Refresh rate" VerticalAlignment="Center" />
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="RefreshRateComboBox" Margin="0,4" />

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Streaming" FontWeight="Bold" Margin="0,12,0,6" />

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Quality preset" VerticalAlignment="Center" />
        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="QualityPresetComboBox" Margin="0,4" />

        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Text="Input" FontWeight="Bold" Margin="0,12,0,6" />

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Input mode" VerticalAlignment="Center" />
        <ComboBox Grid.Row="7" Grid.Column="1" x:Name="InputModeComboBox" Margin="0,4" />

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Pen pressure gamma" VerticalAlignment="Center" />
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <Slider x:Name="PenPressureGammaSlider" Width="160" Minimum="0.5" Maximum="2.0"
                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                    ValueChanged="PenPressureGammaSlider_ValueChanged" />
            <TextBlock x:Name="PenPressureGammaValueText" Width="40" VerticalAlignment="Center" Margin="8,0,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Status" VerticalAlignment="Center" />
        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="StatusTextBlock" Foreground="DarkRed"
                   TextWrapping="Wrap" Margin="0,4" />

        <!-- Session 19: auto-start at Windows logon. The app requires
             Administrator (app.manifest), so this uses a Task Scheduler
             ONLOGON task with highest privileges instead of an HKCU Run key
             (Run keys can't elevate; the task avoids a UAC prompt at every
             logon). Applied immediately on toggle, result shown in Status. -->
        <TextBlock Grid.Row="10" Grid.ColumnSpan="2" Text="System" FontWeight="Bold" Margin="0,12,0,6" />
        <TextBlock Grid.Row="11" Grid.Column="0" Text="Auto start" VerticalAlignment="Center" />
        <CheckBox Grid.Row="11" Grid.Column="1" x:Name="AutoStartCheckBox" Margin="0,4"
                  Content="Khởi động cùng Windows" VerticalAlignment="Center"
                  Click="AutoStartCheckBox_Click" />

        <StackPanel Grid.Row="13" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="80" Margin="0,0,8,0" Click="SaveButton_Click" />
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
